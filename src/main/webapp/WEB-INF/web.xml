<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <display-name>Music App</display-name>

    <servlet>
        <servlet-name>setCookie</servlet-name>
        <servlet-class>com.music.mood.SetCookies</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>setCookie</servlet-name>
        <url-pattern>/setCookies</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>GetCookies</servlet-name>
        <servlet-class>com.music.mood.GetMusicMood</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetCookies</servlet-name>
        <url-pattern>/getDetails</url-pattern>
    </servlet-mapping>
</web-app>